# ==========================================================================
# Environment configuration — standalone build (no Manus/manus.im required)
# Copy this file to .env and fill in real values before running.
# ==========================================================================

NODE_ENV=development
PORT=3000

# --- Auth (required) ---
# Any long random string. Generate with: openssl rand -base64 48
JWT_SECRET=

# Public base URL of this app, used to build links in emails
# (password reset, email verification). No trailing slash.
APP_URL=https://codelearnify.com

# --- Database (required) ---
# MySQL connection string, e.g. mysql://user:password@host:3306/dbname
# Works with PlanetScale, Railway, AWS RDS, or any managed/self-hosted MySQL.
DATABASE_URL=

# --- AI features: AI tutor, copilot, error checker, content generation (required for AI features) ---
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- File storage: course media, avatars, certificates (required for uploads) ---
# Works with AWS S3 directly, or any S3-compatible provider:
# Cloudflare R2, Backblaze B2, DigitalOcean Spaces, MinIO, etc.
S3_BUCKET=
S3_REGION=auto
# Leave S3_ENDPOINT empty for real AWS S3. Set it for R2/B2/Spaces/MinIO, e.g.
# https://<account_id>.r2.cloudflarestorage.com
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- Owner notifications (optional) ---
# If set, system events (e.g. new signups, errors) are emailed here via SMTP.
OWNER_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- Stripe billing (optional, required for premium subscriptions) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- PayPal payment (optional) ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=sandbox

# --- Paddle payment (optional) ---
PADDLE_API_KEY=
PADDLE_CLIENT_ID=
PADDLE_CLIENT_SECRET=
PADDLE_WEBHOOK_SECRET=
PADDLE_MODE=sandbox

# --- Fish Audio Text-to-Speech (optional, required for TTS features) ---
# Get your free API key at https://fish.audio/app/api-keys
# Uses the free S2.1 Pro model (available until July 2026)
FISH_AUDIO_API_KEY=
